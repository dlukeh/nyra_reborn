# --- Nyra AI Agent Configuration ---

# OpenAI API Key (Required for Brain/LLM)
# Get yours at: https://platform.openai.com/
OPENAI_API_KEY=your_api_key_here

# Server Configuration
AI_AGENT_HOST=0.0.0.0
AI_AGENT_PORT=5000
AI_AGENT_DEBUG=0

# Memory Settings
# Set to 1 to enable persistent logging of STM to LTM
MEMORY_CONSOLIDATION_ENABLED=1

# Voice/Animation (Optional)
# Paths to local model weights if not using defaults
WAV2LIP_CHECKPOINT_PATH=modules/animation/checkpoints/wav2lip_gan.pth